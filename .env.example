# Supabase Postgres
GII_DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Temporal (dev server — run `temporal server start-dev`)
GII_TEMPORAL_HOST=localhost:7233
GII_TEMPORAL_NAMESPACE=default
GII_TEMPORAL_TASK_QUEUE=gii-pipeline

# UN Comtrade API
GII_COMTRADE_API_KEY=your-comtrade-api-key

# Google Cloud (GDELT BigQuery)
# Auth option 1: Point to a service account JSON file (recommended for local dev)
GII_GCP_PROJECT_ID=your-gcp-project
GII_GCP_CREDENTIALS_PATH=/path/to/service-account.json
GII_GDELT_DATASET=gdelt-bq.gdeltv2
# Auth option 2: Standard GCP env var (alternative to GII_GCP_CREDENTIALS_PATH)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Auth option 3: On GCP (Cloud Run, GCE, GKE) — no config needed, uses attached service account

# NVIDIA AI (LangChain agents)
GII_NVIDIA_API_KEY=your-nvidia-api-key
GII_LLM_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5

# LangSmith observability (https://smith.langchain.com)
GII_LANGSMITH_API_KEY=your-langsmith-api-key
GII_LANGSMITH_PROJECT=gii
GII_LANGSMITH_TRACING=true

# Index weights (default: 0.40/0.30/0.30)
GII_WEIGHT_TRADE=0.40
GII_WEIGHT_TRAVEL=0.30
GII_WEIGHT_GEOPOLITICS=0.30
